{
  "name": "pixi-graph-engine",
  "version": "0.1.0",
  "description": "High-performance canvas graph engine based on PixiJS 8 + Vue 3 + RBush",
  "type": "module",
  "main": "./dist/pixi-graph-engine.umd.cjs",
  "module": "./dist/pixi-graph-engine.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pixi-graph-engine.js",
      "require": "./dist/pixi-graph-engine.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts && vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:demo": "vite build",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "graph",
    "canvas",
    "pixi",
    "pixijs",
    "vue3",
    "flow",
    "diagram"
  ],
  "peerDependencies": {
    "pixi.js": "^8.0.0",
    "rbush": "^3.0.1",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/rbush": "^4.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "pixi.js": "^8.0.0",
    "rbush": "^3.0.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
